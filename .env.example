# Mercury x402 Service Configuration

# Server Port
PORT=4020

# FRED API Key (required for FRED endpoint)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Server Private Key for Provenance Signatures (required for signatures)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use an existing Ethereum private key (without 0x prefix)
SERVER_PRIVATE_KEY=your_private_key_here
